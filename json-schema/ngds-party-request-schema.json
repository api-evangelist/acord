{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/acord/refs/heads/main/json-schema/ngds-party-request-schema.json",
  "title": "PartyRequest",
  "description": "PartyRequest schema from ACORD NGDS API",
  "type": "object",
  "properties": {
    "partyType": {
      "type": "string",
      "enum": [
        "Insured",
        "Claimant",
        "Agent",
        "Broker",
        "Carrier"
      ]
    },
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    },
    "organizationName": {
      "type": "string"
    },
    "taxId": {
      "type": "string"
    },
    "address": {
      "$ref": "#/components/schemas/Address"
    },
    "contacts": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/Contact"
      }
    }
  },
  "required": [
    "partyType"
  ]
}